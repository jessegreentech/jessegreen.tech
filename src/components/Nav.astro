---
const nav = [
  { label: 'About',   href: '/about'   },
  { label: 'Writing', href: '/writing' },
  { label: 'CV',      href: '/cv'      },
];

const currentPath = Astro.url.pathname;
---

<header class="nav">
  <div class="container nav__inner">
    <a href="/" class="nav__logo" aria-label="Jesse Green — Home">
      <img src="/images/jg-icon-dark.svg" alt="Jesse Green" class="nav__logo-img" />
    </a>

    <nav class="nav__links" aria-label="Primary navigation">
      {nav.map(({ label, href }) => (
        <a
          href={href}
          class={`nav__link ${currentPath.startsWith(href) ? 'nav__link--active' : ''}`}
        >
          {label}
        </a>
      ))}
      <a href="mailto:jesse@jessegreen.tech" class="btn btn--primary nav__cta">
        Contact
      </a>
    </nav>

    <!-- Mobile toggle -->
    <button class="nav__toggle no-print" aria-label="Open menu" id="nav-toggle">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div class="nav__mobile" id="nav-mobile">
    {nav.map(({ label, href }) => (
      <a href={href} class="nav__mobile-link">{label}</a>
    ))}
    <a href="mailto:jesse@jessegreen.tech" class="btn btn--primary" style="margin-top: 1rem;">Contact</a>
  </div>
</header>

<style>
.nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  height: var(--nav-h);
  background: rgba(17, 19, 21, 0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--c-border);
}

.nav__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100%;
}

.nav__logo {
  display: flex;
  align-items: center;
  transition: opacity 0.2s;
}
.nav__logo:hover { opacity: 0.8; }
.nav__logo-img {
  height: 32px;
  width: auto;
  display: block;
}

.nav__links {
  display: flex;
  align-items: center;
  gap: var(--sp-8);
}

.nav__link {
  font-family: var(--f-accent);
  font-size: var(--t-sm);
  font-weight: 500;
  color: var(--c-text-muted);
  letter-spacing: 0.02em;
  transition: color 0.15s;
  position: relative;
}

.nav__link::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0;
  width: 0;
  height: 1px;
  background: var(--c-accent);
  transition: width 0.2s var(--ease);
}

.nav__link:hover,
.nav__link--active {
  color: var(--c-text);
}

.nav__link--active::after,
.nav__link:hover::after {
  width: 100%;
}

.nav__cta { margin-left: var(--sp-4); }

.nav__toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: var(--sp-2);
}

.nav__toggle span {
  display: block;
  width: 22px;
  height: 1.5px;
  background: var(--c-text);
  transition: all 0.2s;
}

.nav__mobile {
  display: none;
  flex-direction: column;
  padding: var(--sp-6) var(--sp-6);
  background: var(--c-surface);
  border-top: 1px solid var(--c-border);
}

.nav__mobile-link {
  font-family: var(--f-accent);
  font-size: var(--t-lg);
  font-weight: 700;
  color: var(--c-text);
  padding: var(--sp-3) 0;
  border-bottom: 1px solid var(--c-border);
}

@media (max-width: 768px) {
  .nav__links { display: none; }
  .nav__toggle { display: flex; }
  .nav__mobile.open { display: flex; }
  .nav { height: auto; }
  .nav__inner { height: var(--nav-h); }
}
</style>

<script>
const toggle = document.getElementById('nav-toggle');
const mobile = document.getElementById('nav-mobile');
toggle?.addEventListener('click', () => mobile?.classList.toggle('open'));
</script>
