---
import Base from '../layouts/Base.astro';

const roles = [
  {
    title: 'Engineering Manager',
    company: 'Kaluza',
    period: 'Jun 2026 – Present',
    location: 'Melbourne, AU',
    bullets: [
      'Engineering Manager at a B2B SaaS company operating in the energy sector.',
    ],
  },
  {
    title: 'Engineering Manager / Platform Owner',
    company: 'SportsBet',
    period: 'Jul 2022 – Jun 2026',
    location: 'Melbourne, AU',
    bullets: [
      'Scaled feature delivery by transitioning from a centralised service model to an inner source platform model.',
      'Led development of an MCP server over an enterprise GraphQL aggregation layer, enabling other teams to build agentic AI features. Delivered a PoC with OAuth 2.0 token exchange; productionised the pattern and established a reusable agent pattern library covering data retrieval, modification, bulk operations, and approval flows.',
      'Member of multiple tech department strategy groups including the 3-year strategy group and AI strategy committee.',
      'Established a cross-cutting platform team to support and deliver enablement work across the engineering organisation.',
    ],
  },
  {
    title: 'Engineering Manager',
    company: 'PlayHQ',
    period: 'Jan 2021 – Jun 2022',
    location: 'Melbourne, AU',
    bullets: [
      'Grew the engineering team rapidly, spinning up multiple new delivery teams and recruiting for both onshore and offshore roles.',
      'Created a framework for surfacing and prioritising non-feature work (platform maintenance, tech debt) alongside product stakeholders.',
      'Introduced support processes that empowered teams to make their own delivery speed vs. quality decisions, with tooling to support those processes.',
    ],
  },
  {
    title: 'Technology Lead',
    company: 'NAB',
    period: 'Sep 2018 – Dec 2020',
    location: 'Melbourne, AU',
    bullets: [
      'Directed and managed a full-stack technology team building an AI-powered chat platform for NAB.',
      'Delivered the chat service across multiple platforms — nab.com, Internet Banking, and both NAB mobile apps.',
      'Scaled the delivery team from one engineer to twelve across three scrum teams.',
    ],
  },
  {
    title: 'Full-stack Engineer',
    company: 'NAB',
    period: 'Jun 2015 – Sep 2018',
    location: 'Melbourne, AU',
    bullets: [
      'Delivered the responsive redesign of nab.com.au, working with Adobe AEM components to ship quality content at launch.',
      'Worked across Angular frameworks and Adobe AEM, developing technical solutions to address customer needs.',
    ],
  },
];

const education = [
  {
    degree: 'AI Programming with Python',
    institution: 'RMIT Online',
    year: '2024',
  },
  {
    degree: 'Bachelor of Information Technology',
    institution: 'RMIT University',
    year: '2010 – 2013',
  },
];

const skills = [
  { category: 'Leadership', items: ['Org Design', 'Engineering Culture', 'Stakeholder Management', 'Executive Communication', 'Platform Strategy'] },
  { category: 'Technical', items: ['AI Implementation', 'Agentic Systems & MCP', 'Front-end (React, HTML, CSS, JS)', 'Back-end (Node.js, Java)', 'Cloud Infrastructure (AWS)'] },
  { category: 'Delivery', items: ['Inner Source Models', 'Tech Debt Strategy', 'Engineering Metrics', 'Incident Management', 'Cross-functional Collaboration'] },
];
---

<Base
  title="CV"
  description="Professional CV — engineering manager and technology leader with a track record across fintech, sportstech, and energy sectors."
>
  <!-- ── PAGE HEADER ──────────────────────────── -->
  <div class="page-header no-print">
    <div class="container">
      <span class="label">Curriculum Vitae</span>
      <div class="page-header__row">
        <h1 class="page-title">
          The career so far.<br />
          <span class="accent">Ten years. Three industries. One throughline.</span>
        </h1>
        <button class="btn btn--ghost" onclick="window.print()">
          ↓ Download PDF
        </button>
      </div>
    </div>
  </div>

  <!-- ── CV BODY ────────────────────────────────── -->
  <section class="section cv-section">
    <div class="container cv-container">

      <!-- Print header (hidden on screen) -->
      <div class="cv-print-header print-only">
        <h1 class="cv-name">Jesse Green</h1>
        <p class="cv-print-meta">
          Engineering Manager · Technology Leader · Melbourne, AU<br />
          jesse@jessegreen.tech · linkedin.com/in/jessergreen · jessegreen.tech
        </p>
          <div class="cv-print-divider"></div>
      </div>

      <div class="cv-grid">
        <!-- Main column -->
        <div class="cv-main">

          <!-- Summary -->
          <div class="cv-block">
            <h2 class="cv-section-heading">
              <span class="cv-dot cv-section-dot" aria-hidden="true"></span>
              Profile
            </h2>
            <p class="cv-summary">
              Engineering leader with a decade of experience operating at the intersection of engineering systems and business strategy. Track record of building delivery-focused teams, translating complex technical realities into decisions that land with executives, and shipping at scale across fintech, sportstech, and energy. Former engineer. Still thinks like one.
            </p>
          </div>

          <!-- Experience -->
          <div class="cv-block">
            <h2 class="cv-section-heading">
              <span class="cv-dot cv-section-dot" aria-hidden="true"></span>
              Experience
            </h2>

            {roles.map(role => (
              <div class="cv-role">
                <div class="cv-role__header">
                  <div>
                    <h3 class="cv-role__title">{role.title}</h3>
                    <div class="cv-role__company">{role.company} · {role.location}</div>
                  </div>
                  <span class="cv-role__period">{role.period}</span>
                </div>
                <ul class="cv-role__bullets">
                  {role.bullets.map(b => (
                    <li class="cv-bullet">
                      <span class="cv-dot cv-bullet__dot" aria-hidden="true"></span>
                      <span>{b}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>

          <!-- Education -->
          <div class="cv-block">
            <h2 class="cv-section-heading">
              <span class="cv-dot cv-section-dot" aria-hidden="true"></span>
              Education
            </h2>
            {education.map(e => (
              <div class="cv-edu">
                <h3 class="cv-edu__degree">{e.degree}</h3>
                <div class="cv-edu__meta muted">{e.institution} · {e.year}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="cv-sidebar">

          <!-- Contact -->
          <div class="cv-widget no-print">
            <span class="label cv-widget__label">Contact</span>
            <div class="cv-contact-list">
              <a href="mailto:jesse@jessegreen.tech" class="cv-contact-item">
                jesse@jessegreen.tech
              </a>
              <a href="https://linkedin.com/in/jessergreen" class="cv-contact-item" target="_blank">
                LinkedIn
              </a>
              <a href="https://github.com/jessegreentech" class="cv-contact-item" target="_blank">
                GitHub
              </a>
            </div>
          </div>

          <!-- Skills -->
          {skills.map(group => (
            <div class="cv-widget">
              <span class="label cv-widget__label">{group.category}</span>
              <ul class="cv-skill-list">
                {group.items.map(skill => (
                  <li class="cv-skill-item">{skill}</li>
                ))}
              </ul>
            </div>
          ))}

          <!-- Download CTA (screen only) -->
          <div class="cv-widget cv-widget--download no-print">
            <button class="btn btn--primary" onclick="window.print()">
              ↓ Download PDF
            </button>
            <p class="subtle cv-download-hint">
              Use browser print → Save as PDF
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Base>

<style>
.accent { color: var(--c-accent); }

.page-header {
  padding-top: calc(var(--nav-h) + var(--sp-16));
  padding-bottom: var(--sp-16);
  border-bottom: 1px solid var(--c-border);
  background: var(--c-surface);
}

.page-header__row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: var(--sp-8);
  margin-top: var(--sp-4);
}

.page-title {
  font-size: clamp(2rem, 3.5vw, 3rem);
  margin-top: 0;
}

/* ─── CV LAYOUT ──── */
.cv-container {
  max-width: 960px;
}

.cv-grid {
  display: grid;
  grid-template-columns: 1fr 260px;
  gap: var(--sp-12);
  align-items: start;
}

/* ─── SECTION HEADINGS ──── */
.cv-section-heading {
  font-size: var(--t-xs);
  font-family: var(--f-accent);
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--c-text-muted);
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  margin-bottom: var(--sp-6);
  padding-bottom: var(--sp-3);
  border-bottom: 1px solid var(--c-border);
}

.cv-dot {
  border-radius: 50%;
  background: var(--c-accent);
  flex-shrink: 0;
}

.cv-section-dot {
  width: 6px;
  height: 6px;
}

.cv-block {
  margin-bottom: var(--sp-12);
}

/* ─── SUMMARY ──── */
.cv-summary {
  font-size: var(--t-base);
  line-height: 1.75;
  color: var(--c-text-muted);
  max-width: 65ch;
}

/* ─── ROLES ──── */
.cv-role {
  margin-bottom: var(--sp-8);
  padding-bottom: var(--sp-8);
  border-bottom: 1px solid var(--c-border);
}

.cv-role:last-child { border-bottom: none; }

.cv-role__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: var(--sp-4);
  margin-bottom: var(--sp-4);
}

.cv-role__title {
  font-size: var(--t-lg);
  font-weight: 800;
  line-height: 1.2;
  margin-bottom: var(--sp-1);
}

.cv-role__company {
  font-family: var(--f-accent);
  font-size: var(--t-sm);
  font-weight: 500;
  color: var(--c-text-muted);
}

.cv-role__period {
  font-family: var(--f-accent);
  font-size: var(--t-xs);
  font-weight: 700;
  color: var(--c-accent);
  white-space: nowrap;
  letter-spacing: 0.04em;
}

.cv-role__bullets {
  display: flex;
  flex-direction: column;
  gap: var(--sp-3);
}

.cv-bullet {
  display: flex;
  gap: var(--sp-3);
  align-items: flex-start;
  font-size: var(--t-sm);
  color: var(--c-text-muted);
  line-height: 1.65;
}

.cv-bullet__dot {
  width: 4px;
  height: 4px;
  margin-top: 8px;
}

/* ─── EDUCATION ──── */
.cv-edu {
  margin-bottom: var(--sp-4);
}

.cv-edu__degree {
  font-size: var(--t-base);
  font-weight: 700;
  margin-bottom: var(--sp-1);
}

/* ─── SIDEBAR ──── */
.cv-sidebar {
  position: sticky;
  top: calc(var(--nav-h) + var(--sp-8));
  display: flex;
  flex-direction: column;
  gap: var(--sp-4);
  align-self: start;
}

/* ─── SIDEBAR WIDGETS ──── */
.cv-widget {
  background: var(--c-surface);
  border: 1px solid var(--c-border);
  border-radius: 2px;
  padding: var(--sp-6);
}

.cv-widget--download .btn {
  width: 100%;
  justify-content: center;
}

.cv-download-hint {
  font-size: var(--t-xs);
  font-family: var(--f-accent);
  margin-top: 0.75rem;
  text-align: center;
}

.cv-widget__label {
  display: block;
  margin-bottom: var(--sp-4);
}

.cv-contact-list {
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
}

.cv-contact-item {
  font-family: var(--f-accent);
  font-size: var(--t-sm);
  color: var(--c-text-muted);
  transition: color 0.15s;
}

.cv-contact-item:hover { color: var(--c-accent); }

.cv-skill-list {
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
}

.cv-skill-item {
  font-family: var(--f-accent);
  font-size: var(--t-sm);
  color: var(--c-text-muted);
  padding: var(--sp-1) 0;
  border-bottom: 1px solid var(--c-border);
}

.cv-skill-item:last-child { border-bottom: none; }

.cv-print-divider {
  height: 2px;
  background: var(--c-accent);
  margin: 1rem 0 2rem;
}

/* ─── PRINT ──── */
.cv-print-header { display: none; }
.print-only { display: none; }

@media print {
  .cv-section { padding: 0; }
  .cv-print-header { display: block; }
  .cv-sidebar { position: static; }
  .cv-grid { grid-template-columns: 1fr 220px; gap: 2rem; }

  
}

/* ─── RESPONSIVE ──── */
@media (max-width: 900px) {
  .cv-grid { grid-template-columns: 1fr; }
  .cv-sidebar {
    position: static;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-4);
  }
}

@media (max-width: 600px) {
  .cv-sidebar { grid-template-columns: 1fr; }
  .cv-role__header { flex-direction: column; }
}
</style>

<style is:global>
@media print {
  .page-header {
    display: none !important;
  }

  main {
    padding: 0 !important;
    margin: 0 !important;
  }

  .cv-grid {
    grid-template-columns: 1fr 140px !important;
  }

  .cv-widget__label {
    font-size: 0.6rem !important;
  }

  .cv-skill-item,
  .cv-contact-item {
    font-size: 0.65rem !important;
    word-break: break-word !important;
  }
}
</style>