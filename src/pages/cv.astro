---
import Base from '../layouts/Base.astro';

const roles = [
  {
    title: 'Head of Engineering / VP Technology',
    company: '[Company Name]',
    period: '20XX – Present',
    location: 'Melbourne, AU',
    bullets: [
      'Led architectural transformation of [X] platform serving [Y] users, reducing deployment lead time by [Z]%.',
      'Built and scaled engineering organisation from [X] to [Y] engineers across [N] distributed teams.',
      'Drove $[X]M reduction in infrastructure cost through systematic tech debt remediation programme.',
      'Partnered with C-suite to translate [strategic initiative] into a [technical outcome] delivered in [timeframe].',
    ],
  },
  {
    title: 'Engineering Manager / Principal Engineer',
    company: '[Previous Company]',
    period: '20XX – 20XX',
    location: 'Melbourne, AU',
    bullets: [
      'Designed and shipped [key system] handling [scale indicator], now core to [business function].',
      'Established engineering practices (code review, incident response, on-call) adopted across [X] teams.',
      'Mentored [N] engineers to senior level; [X] now in leadership positions.',
    ],
  },
  {
    title: 'Senior Software Engineer',
    company: '[Earlier Company]',
    period: '20XX – 20XX',
    location: '[City], AU',
    bullets: [
      'Technical lead for [project], responsible for architecture, delivery, and stakeholder communication.',
      'Introduced [technology/practice] that became standard across the engineering organisation.',
    ],
  },
];

const education = [
  {
    degree: '[Degree] in [Field]',
    institution: '[University]',
    year: '20XX',
  },
];

const skills = [
  { category: 'Leadership', items: ['Org Design', 'Engineering Culture', 'Stakeholder Management', 'P&L Ownership', 'Executive Communication'] },
  { category: 'Architecture', items: ['Distributed Systems', 'Platform Engineering', 'Cloud Infrastructure (AWS/GCP)', 'ML/AI Systems', 'API Design'] },
  { category: 'Delivery', items: ['Engineering Metrics', 'DORA Framework', 'Tech Debt Strategy', 'Incident Management', 'Agile at Scale'] },
];
---

<Base
  title="CV"
  description="Professional CV — technology executive, engineering leader, strategic translator."
>
  <!-- ── PAGE HEADER ──────────────────────────── -->
  <div class="page-header no-print">
    <div class="container">
      <span class="label">Curriculum Vitae</span>
      <div class="page-header__row">
        <h1 class="page-title">
          Full history.<br />
          <span class="accent">Structured for decisions.</span>
        </h1>
        <button class="btn btn--ghost no-print" onclick="window.print()">
          ↓ Download PDF
        </button>
      </div>
    </div>
  </div>

  <!-- ── CV BODY ────────────────────────────────── -->
  <section class="section cv-section">
    <div class="container cv-container">

      <!-- Print header (hidden on screen) -->
      <div class="cv-print-header print-only">
        <h1 class="cv-name">[Your Name]</h1>
        <p class="cv-print-meta">
          Head of Engineering · Technology Executive · Melbourne, AU<br />
          hello@yourdomain.com · linkedin.com/in/yourhandle · jg-tech-thinking.com
        </p>
        <div style="height: 2px; background: #FF5500; margin: 1rem 0 2rem;"></div>
      </div>

      <div class="cv-grid">
        <!-- Main column -->
        <div class="cv-main">

          <!-- Summary -->
          <div class="cv-block">
            <h2 class="cv-section-heading">
              <span class="cv-section-dot" aria-hidden="true"></span>
              Profile
            </h2>
            <p class="cv-summary">
              Technology executive with [X]+ years operating at the intersection of 
              engineering systems and business strategy. Track record of building 
              high-performing engineering organisations, translating complex technical 
              realities into executive decisions, and delivering architectural outcomes 
              at enterprise scale. Currently targeting Head of Engineering / GM Technology 
              roles in high-complexity organisations.
            </p>
          </div>

          <!-- Experience -->
          <div class="cv-block">
            <h2 class="cv-section-heading">
              <span class="cv-section-dot" aria-hidden="true"></span>
              Experience
            </h2>

            {roles.map(role => (
              <div class="cv-role">
                <div class="cv-role__header">
                  <div>
                    <h3 class="cv-role__title">{role.title}</h3>
                    <div class="cv-role__company">{role.company} · {role.location}</div>
                  </div>
                  <span class="cv-role__period">{role.period}</span>
                </div>
                <ul class="cv-role__bullets">
                  {role.bullets.map(b => (
                    <li class="cv-bullet">
                      <span class="cv-bullet__dot" aria-hidden="true"></span>
                      <span>{b}</span>
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>

          <!-- Education -->
          <div class="cv-block">
            <h2 class="cv-section-heading">
              <span class="cv-section-dot" aria-hidden="true"></span>
              Education
            </h2>
            {education.map(e => (
              <div class="cv-edu">
                <h3 class="cv-edu__degree">{e.degree}</h3>
                <div class="cv-edu__meta muted">{e.institution} · {e.year}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="cv-sidebar">

          <!-- Contact — print only -->
          <div class="cv-widget print-hide">
            <span class="label cv-widget__label">Contact</span>
            <div class="cv-contact-list">
              <a href="mailto:hello@yourdomain.com" class="cv-contact-item">
                hello@yourdomain.com
              </a>
              <a href="https://linkedin.com/in/yourhandle" class="cv-contact-item" target="_blank">
                LinkedIn
              </a>
              <a href="https://github.com/yourhandle" class="cv-contact-item" target="_blank">
                GitHub
              </a>
            </div>
          </div>

          <!-- Skills -->
          {skills.map(group => (
            <div class="cv-widget">
              <span class="label cv-widget__label">{group.category}</span>
              <ul class="cv-skill-list">
                {group.items.map(skill => (
                  <li class="cv-skill-item">{skill}</li>
                ))}
              </ul>
            </div>
          ))}

          <!-- Download CTA (screen only) -->
          <div class="cv-widget no-print">
            <button class="btn btn--primary" style="width: 100%; justify-content: center;" onclick="window.print()">
              ↓ Download as PDF
            </button>
            <p class="subtle" style="font-size: var(--t-xs); font-family: var(--f-accent); margin-top: 0.75rem; text-align: center;">
              Use browser print → Save as PDF
            </p>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Base>

<style>
.accent { color: var(--c-accent); }

.page-header {
  padding-top: calc(var(--nav-h) + var(--sp-12));
  padding-bottom: var(--sp-10);
  border-bottom: 1px solid var(--c-border);
  background: var(--c-surface);
}

.page-header__row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: var(--sp-8);
}

.page-title {
  font-size: clamp(2rem, 3.5vw, 3rem);
  margin-top: var(--sp-4);
}

/* ─── CV LAYOUT ──── */
.cv-container {
  max-width: 960px;
}

.cv-grid {
  display: grid;
  grid-template-columns: 1fr 260px;
  gap: var(--sp-12);
  align-items: start;
}

/* ─── SECTION HEADINGS ──── */
.cv-section-heading {
  font-size: var(--t-xs);
  font-family: var(--f-accent);
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--c-text-muted);
  display: flex;
  align-items: center;
  gap: var(--sp-3);
  margin-bottom: var(--sp-6);
  padding-bottom: var(--sp-3);
  border-bottom: 1px solid var(--c-border);
}

.cv-section-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--c-accent);
  flex-shrink: 0;
}

.cv-block {
  margin-bottom: var(--sp-12);
}

/* ─── SUMMARY ──── */
.cv-summary {
  font-size: var(--t-base);
  line-height: 1.75;
  color: var(--c-text-muted);
  max-width: 65ch;
}

/* ─── ROLES ──── */
.cv-role {
  margin-bottom: var(--sp-8);
  padding-bottom: var(--sp-8);
  border-bottom: 1px solid var(--c-border);
}

.cv-role:last-child { border-bottom: none; }

.cv-role__header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: var(--sp-4);
  margin-bottom: var(--sp-4);
}

.cv-role__title {
  font-size: var(--t-lg);
  font-weight: 800;
  line-height: 1.2;
  margin-bottom: var(--sp-1);
}

.cv-role__company {
  font-family: var(--f-accent);
  font-size: var(--t-sm);
  font-weight: 500;
  color: var(--c-text-muted);
}

.cv-role__period {
  font-family: var(--f-accent);
  font-size: var(--t-xs);
  font-weight: 700;
  color: var(--c-accent);
  white-space: nowrap;
  letter-spacing: 0.04em;
}

.cv-role__bullets {
  display: flex;
  flex-direction: column;
  gap: var(--sp-3);
}

.cv-bullet {
  display: flex;
  gap: var(--sp-3);
  align-items: flex-start;
  font-size: var(--t-sm);
  color: var(--c-text-muted);
  line-height: 1.65;
}

.cv-bullet__dot {
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: var(--c-accent);
  flex-shrink: 0;
  margin-top: 8px;
}

/* ─── EDUCATION ──── */
.cv-edu {
  margin-bottom: var(--sp-4);
}

.cv-edu__degree {
  font-size: var(--t-base);
  font-weight: 700;
  margin-bottom: var(--sp-1);
}

/* ─── SIDEBAR WIDGETS ──── */
.cv-widget {
  background: var(--c-surface);
  border: 1px solid var(--c-border);
  border-radius: 2px;
  padding: var(--sp-6);
  margin-bottom: var(--sp-4);
}

.cv-widget__label {
  display: block;
  margin-bottom: var(--sp-4);
}

.cv-contact-list {
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
}

.cv-contact-item {
  font-family: var(--f-accent);
  font-size: var(--t-sm);
  color: var(--c-text-muted);
  transition: color 0.15s;
}

.cv-contact-item:hover { color: var(--c-accent); }

.cv-skill-list {
  display: flex;
  flex-direction: column;
  gap: var(--sp-2);
}

.cv-skill-item {
  font-family: var(--f-accent);
  font-size: var(--t-sm);
  color: var(--c-text-muted);
  padding: var(--sp-1) 0;
  border-bottom: 1px solid var(--c-border);
}

.cv-skill-item:last-child { border-bottom: none; }

/* ─── PRINT ──── */
.cv-print-header { display: none; }
.print-only { display: none; }

@media print {
  .page-header { display: none; }
  .cv-section { padding-top: 0; }
  .cv-print-header { display: block; }
  .cv-grid { grid-template-columns: 1fr 220px; gap: 2rem; }
  .cv-widget { border-color: #ddd; background: #f9f9f9; }
  .cv-section-heading { color: #555; border-color: #ddd; }
  .cv-bullet { color: #333; }
  .cv-role { border-color: #ddd; }
  .cv-role__period { color: #FF5500; }
  .cv-summary { color: #333; }
  .cv-contact-item, .cv-skill-item { color: #333; }
  .cv-role__company { color: #555; }
  .cv-edu__meta { color: #555; }
  .print-hide { display: none !important; }
}

/* ─── RESPONSIVE ──── */
@media (max-width: 900px) {
  .cv-grid { grid-template-columns: 1fr; }
  .cv-sidebar { display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-4); }
}

@media (max-width: 600px) {
  .cv-sidebar { grid-template-columns: 1fr; }
  .cv-role__header { flex-direction: column; }
  .page-header__row { flex-direction: column; align-items: flex-start; }
}
</style>
