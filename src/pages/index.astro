---
import Base from '../layouts/Base.astro';

const pillars = [
  {
    number: '01',
    title: 'Strategic Translation',
    body: 'Converting engineering reality into business velocity. And converting enterprise vision into architectural decisions that actually ship.',
    tag: 'The Bridge',
  },
  {
    number: '02',
    title: 'High-Velocity Org Design',
    body: 'Past agile templates and into genuine team performance. Measuring what matters: delivery culture, frictionless systems, and real engineering throughput.',
    tag: 'Modern Teams',
  },
  {
    number: '03',
    title: 'System Pragmatism & Governance',
    body: 'Opinionated positions on stack decisions, tech debt economics, and the structural reality of leading enterprise software at scale.',
    tag: 'Opinionated Strategy',
  },
];
---

<Base title="Home">
  <!-- ── HERO ─────────────────────────────────── -->
  <section class="hero noise" aria-label="Introduction">
    <div class="container hero__inner">
      <div class="hero__content">
        <span class="label hero__eyebrow">JG Tech Thinking</span>
        <h1 class="hero__headline">
          The gap between<br />
          <em class="hero__em">engineering</em> and<br />
          <em class="hero__em">executive</em> is where<br />
          decisions break.
        </h1>
        <p class="hero__body muted">
          I operate at that gap. Translating complex engineering realities 
          into high-level business strategy — and converting enterprise 
          vision into high-performing architectural decisions.
        </p>
        <div class="hero__actions">
          <a href="/about" class="btn btn--primary">Executive Profile</a>
          <a href="/writing" class="btn btn--ghost">Read the thinking</a>
        </div>
      </div>

      <div class="hero__diagram" aria-hidden="true">
        <!-- Industrial framework diagram: SVG -->
        <svg viewBox="0 0 480 420" fill="none" xmlns="http://www.w3.org/2000/svg" class="hero__svg">
          <!-- Grid lines -->
          <line x1="0" y1="0" x2="480" y2="0" stroke="#2A2F35" stroke-width="1"/>
          <line x1="0" y1="140" x2="480" y2="140" stroke="#2A2F35" stroke-width="1"/>
          <line x1="0" y1="280" x2="480" y2="280" stroke="#2A2F35" stroke-width="1"/>
          <line x1="0" y1="420" x2="480" y2="420" stroke="#2A2F35" stroke-width="1"/>
          <line x1="0" y1="0" x2="0" y2="420" stroke="#2A2F35" stroke-width="1"/>
          <line x1="160" y1="0" x2="160" y2="420" stroke="#2A2F35" stroke-width="1"/>
          <line x1="320" y1="0" x2="320" y2="420" stroke="#2A2F35" stroke-width="1"/>
          <line x1="480" y1="0" x2="480" y2="420" stroke="#2A2F35" stroke-width="1"/>

          <!-- Executive layer -->
          <rect x="40" y="28" width="400" height="84" fill="#1A1D20" stroke="#2A2F35" stroke-width="1" rx="1"/>
          <text x="56" y="60" fill="#B0B3B8" font-family="Space Grotesk, sans-serif" font-size="10" font-weight="700" letter-spacing="2" text-transform="uppercase">EXECUTIVE LAYER</text>
          <text x="56" y="84" fill="white" font-family="Space Grotesk, sans-serif" font-size="13" font-weight="700">Business Velocity · Strategy · P&amp;L</text>
          <rect x="56" y="92" width="180" height="3" fill="#FF5500" rx="1"/>

          <!-- Bridge / Translation layer — orange accent -->
          <rect x="80" y="162" width="320" height="56" fill="rgba(255,85,0,0.08)" stroke="#FF5500" stroke-width="1.5" rx="1"/>
          <text x="100" y="187" fill="#FF5500" font-family="Space Grotesk, sans-serif" font-size="10" font-weight="700" letter-spacing="2">TRANSLATION LAYER</text>
          <text x="100" y="205" fill="white" font-family="Space Grotesk, sans-serif" font-size="12" font-weight="500">Strategic alignment · Decision translation</text>

          <!-- Engineering layer -->
          <rect x="40" y="308" width="400" height="84" fill="#1A1D20" stroke="#2A2F35" stroke-width="1" rx="1"/>
          <text x="56" y="340" fill="#B0B3B8" font-family="Space Grotesk, sans-serif" font-size="10" font-weight="700" letter-spacing="2">ENGINEERING LAYER</text>
          <text x="56" y="364" fill="white" font-family="Space Grotesk, sans-serif" font-size="13" font-weight="700">Architecture · Systems · Delivery</text>
          <rect x="56" y="372" width="120" height="3" fill="#2A2F35" rx="1"/>

          <!-- Connector arrows -->
          <line x1="240" y1="112" x2="240" y2="162" stroke="#FF5500" stroke-width="1.5" stroke-dasharray="4 3"/>
          <line x1="240" y1="218" x2="240" y2="308" stroke="#FF5500" stroke-width="1.5" stroke-dasharray="4 3"/>
          <polygon points="234,160 240,172 246,160" fill="#FF5500"/>
          <polygon points="234,306 240,318 246,306" fill="#FF5500"/>
        </svg>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="hero__scroll" aria-hidden="true">
      <span class="subtle" style="font-family: var(--f-accent); font-size: var(--t-xs); letter-spacing: 0.1em;">SCROLL</span>
      <div class="hero__scroll-line"></div>
    </div>
  </section>

  <!-- ── PILLARS ────────────────────────────────── -->
  <section class="section pillars" aria-labelledby="pillars-heading">
    <div class="container">
      <div class="pillars__header">
        <span class="label">Core Competencies</span>
        <div class="divider--orange" style="margin-top: 1rem;"></div>
      </div>

      <div class="pillars__grid">
        {pillars.map((p) => (
          <article class="pillar-card">
            <div class="pillar-card__number subtle">{p.number}</div>
            <span class="pillar-tag">{p.tag}</span>
            <h3 class="pillar-card__title">{p.title}</h3>
            <p class="pillar-card__body muted">{p.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── WRITING STRIP ──────────────────────────── -->
  <section class="section--tight writing-strip" aria-label="Latest writing">
    <div class="container writing-strip__inner">
      <div>
        <span class="label">Latest Thinking</span>
        <h2 style="margin-top: 0.75rem; font-size: var(--t-2xl);">
          Opinions backed by<br />operational reality.
        </h2>
      </div>
      <a href="/writing" class="btn btn--ghost">
        View all writing →
      </a>
    </div>
  </section>
</Base>

<style>
/* ─── HERO ──── */
.hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding-top: var(--nav-h);
  position: relative;
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  top: -20%;
  right: -10%;
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(255,85,0,0.06) 0%, transparent 65%);
  pointer-events: none;
}

.hero__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--sp-16);
  align-items: center;
  padding-top: var(--sp-16);
  padding-bottom: var(--sp-16);
}

.hero__eyebrow {
  display: block;
  margin-bottom: var(--sp-6);
}

.hero__headline {
  font-size: clamp(2.5rem, 5vw, 4.5rem);
  font-weight: 800;
  line-height: 1.05;
  letter-spacing: -0.03em;
  margin-bottom: var(--sp-6);
}

.hero__em {
  font-style: normal;
  color: var(--c-accent);
}

.hero__body {
  font-size: var(--t-lg);
  line-height: 1.7;
  margin-bottom: var(--sp-8);
  max-width: 52ch;
}

.hero__actions {
  display: flex;
  gap: var(--sp-4);
  flex-wrap: wrap;
}

.hero__svg {
  width: 100%;
  opacity: 0.9;
}

.hero__scroll {
  position: absolute;
  bottom: var(--sp-8);
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--sp-3);
}

.hero__scroll-line {
  width: 1px;
  height: 48px;
  background: linear-gradient(to bottom, var(--c-accent), transparent);
  animation: scrollPulse 2s ease-in-out infinite;
}

@keyframes scrollPulse {
  0%, 100% { opacity: 0.4; transform: scaleY(1); }
  50% { opacity: 1; transform: scaleY(1.1); }
}

/* ─── PILLARS ──── */
.pillars__header {
  margin-bottom: var(--sp-12);
}

.pillars__grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--sp-6);
}

.pillar-card {
  background: var(--c-surface);
  border: 1px solid var(--c-border);
  border-radius: 2px;
  padding: var(--sp-8);
  transition: border-color 0.2s var(--ease), background 0.2s;
  position: relative;
  overflow: hidden;
}

.pillar-card::before {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: var(--c-accent);
  transform: scaleX(0);
  transform-origin: left;
  transition: transform 0.3s var(--ease);
}

.pillar-card:hover { border-color: rgba(255,85,0,0.3); }
.pillar-card:hover::before { transform: scaleX(1); }

.pillar-card__number {
  font-family: var(--f-accent);
  font-size: var(--t-xs);
  font-weight: 700;
  letter-spacing: 0.1em;
  margin-bottom: var(--sp-4);
}

.pillar-card__title {
  font-size: var(--t-xl);
  font-weight: 800;
  margin: var(--sp-3) 0 var(--sp-4);
  line-height: 1.2;
}

.pillar-card__body {
  font-size: var(--t-sm);
  line-height: 1.7;
}

/* ─── WRITING STRIP ──── */
.writing-strip {
  background: var(--c-surface);
  border-top: 1px solid var(--c-border);
  border-bottom: 1px solid var(--c-border);
}

.writing-strip__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--sp-8);
}

/* ─── RESPONSIVE ──── */
@media (max-width: 1024px) {
  .hero__inner { grid-template-columns: 1fr; }
  .hero__diagram { display: none; }
  .pillars__grid { grid-template-columns: 1fr; }
}

@media (max-width: 768px) {
  .writing-strip__inner { flex-direction: column; align-items: flex-start; }
}
</style>
